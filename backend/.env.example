NODE_ENV=development
PORT=3000

# Frontend URL 
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
# Change this to your local MySQL password
DATABASE_PASSWORD=root
DATABASE_NAME=english_scorer

# Auth (Generate random UUIDs or random strings for secrets)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# Cloudinary (Image Hosting)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=BandMates/Task_1_academic

# AI Integration
GEMINI_API_KEY=your_google_gemini_api_key_here

# AI Usage Limits (Quotas)
AI_LIMIT_PRACTICE_GUEST=2
AI_LIMIT_PRACTICE_USER=6
AI_LIMIT_VOCAB_GUEST=5
AI_LIMIT_VOCAB_USER=10
